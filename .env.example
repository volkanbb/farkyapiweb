# Environment Variables Example

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=farkyapi_db
DB_USER=postgres
DB_PASSWORD=SecurePassword123!

# Backend
ASPNETCORE_ENVIRONMENT=Development
JWT_SECRET=super_secret_key_which_is_very_long_and_secure_for_jwt_signing
JWT_ISSUER=FarkYapiWeb
JWT_AUDIENCE=FarkYapiWebClient
JWT_EXPIRATION_MINUTES=60
REFRESH_TOKEN_EXPIRATION_DAYS=7

# Frontend
NODE_ENV=development
PORT=4000
API_URL=http://localhost/api/v1
